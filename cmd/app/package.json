{
  "name": "GoMud",
  "version": "1.0.0",
  "description": "GoMudClient",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:steam-mac": "electron-builder --mac --config steam-builder.json",
    "build:steam-win": "electron-builder --win --config steam-builder.json",
    "build:steam-linux": "electron-builder --linux --config steam-builder.json"
  },
  "dependencies": {
    "steamworks.js": "^0.4.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.gomudclient.app",
    "productName": "GoMudClient",
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "main.js",
      "build_cache/webclient-pure.html",
      "build_cache/static/**/*"
    ]
  }
}
